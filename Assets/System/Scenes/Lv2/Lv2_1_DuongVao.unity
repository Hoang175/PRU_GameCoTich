  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4f6a8477a5db69944b7aca9b8ad3ef91, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPC_Dialogue
  lines:
  - 'Tam: Uncle, I was walking the buffalo back but saw our house is closed tight
    today. Why is that?'
  - 'Farmer: Good heavens, is that you Tam? Where have you been while your stepmother
    and Cam have been looking everywhere for you! She''s standing akimbo cursing
    loudly over there at the house!'
  - 'Tam: Oh no... Auntie must have found out about my little Bong. I have to go
    inside right away!'
  - 'Farmer: Poor child. You''ll get a severe beating if you go back now. You must
    step lightly, sneak in through the back yard, got it?'
  interactTooltipUI: {fileID: 1337773807}
  talkSound: {fileID: 0}
