--- !u!114 &199478966
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 199478962}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4f6a8477a5db69944b7aca9b8ad3ef91, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPC_Dialogue
  lines:
  - "T\u1EA5m: B\xE1c \u01A1i, ch\xE1u \u0111i ch\u0103n tr\xE2u v\u1EC1 ngang qua,
    sao nh\xE0 ch\xE1u h\xF4m nay \u0111\xF3ng c\u1EEDa im \u1EC9m th\u1EBF \u1EA1?"
  - "B\xE1c N\xF4ng D\xE2n: Tr\u1EDDi \u0111\u1EA5t, T\u1EA5m \u0111\u1EA5y \xE0?
    \u0110i \u0111\xE2u m\xE0 d\xEC gh\u1EBB m\xE0y v\u1EDBi con C\xE1m n\xF3 \u0111i
    t\xECm n\xE3y gi\u1EDD! N\xF3 \u0111ang ch\u1ED1ng n\u1EA1nh ch\u1EEDi b\u1EDBi
    \u1ECFm t\u1ECFi \u1EDF nh\xE0 kia k\xECa!"
  - "T\u1EA5m: Ch\u1EBFt r\u1ED3i... ch\u1EAFc D\xEC ph\xE1t hi\u1EC7n ra b\xE9 B\u1ED1ng
    c\u1EE7a ch\xE1u r\u1ED3i. Ch\xE1u ph\u1EA3i l\u1EBBn v\xE0o xem sao!"
  - "B\xE1c N\xF4ng D\xE2n: Kh\u1ED5 th\xE2n con b\xE9. Ch\xE1u v\xE1c c\xE1i m\u1EB7t
    v\xE0o b\xE2y gi\u1EDD l\xE0 \u0103n \u0111\xF2n no \u0111\xF2n \u0111\u1EA5y.
    Ph\u1EA3i \u0111i nh\u1EB9 n\xF3i kh\u1EBD, l\xE9n l\xFAt m\xE0 v\xE0o s\xE2n
    sau th\xF4i, r\xF5 ch\u01B0a?"
  interactTooltipUI: {fileID: 1337773807}
  talkSound: {fileID: 0}
